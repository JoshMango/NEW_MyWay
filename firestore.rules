rules_version = '2';
// MyWay Firestore security rules. Deploy from the Firebase console (Firestore → Rules)
// or `firebase deploy --only firestore:rules`. Model notes live in the *.kt data files.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function mine(uid)  { return signedIn() && request.auth.uid == uid; }
    function groupMembers(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)).data.members;
    }
    function inGroup(gid) { return signedIn() && request.auth.uid in groupMembers(gid); }

    // Profiles — anyone signed in can look up / search users; you write only your own doc.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if mine(uid);
    }

    // @tag uniqueness index. Claim/rename only points a handle at yourself; you can free your own.
    match /usernames/{lower} {
      allow read:   if signedIn();
      allow write:  if signedIn()
                    && request.resource.data.uid == request.auth.uid
                    && (resource == null || resource.data.uid == request.auth.uid);
      allow delete: if resource.data.uid == request.auth.uid;
    }

    // Friend requests — sender creates; either party reads/deletes.
    match /friendRequests/{id} {
      allow create: if request.resource.data.from == request.auth.uid;
      allow read, delete: if signedIn()
                    && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // Friendships — either member of the pair may create/read/delete.
    match /friendships/{pair} {
      allow create: if signedIn() && request.auth.uid in request.resource.data.users;
      allow read, delete: if signedIn() && request.auth.uid in resource.data.users;
    }

    // Groups — members read; owner creates; members update (roster/photo/tripActive enforced client-side).
    match /groups/{gid} {
      allow read:   if signedIn() && request.auth.uid in resource.data.members;
      allow create: if request.auth.uid == request.resource.data.owner;
      allow update: if signedIn() && request.auth.uid in resource.data.members;
      allow delete: if signedIn() && request.auth.uid == resource.data.owner;

      // Chat messages + shared trip pins — any group member.
      match /messages/{mid}  { allow read, create: if inGroup(gid); }
      match /trip_pins/{pid} { allow read, write: if inGroup(gid); }
    }

    // Trip participation — ONE doc per user keyed by uid (single-trip-at-a-time).
    // You write only your own; any group member may delete a participant when ending the session.
    match /trip_participants/{uid} {
      allow read: if signedIn();
      allow create, update: if mine(uid);
      allow delete: if mine(uid) || inGroup(resource.data.gid);
    }
  }
}
