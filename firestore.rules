rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function member(gid) {
      return signedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(gid)).data.members;
    }

    // Profiles — anyone signed in can look up / search users; you write only your own doc.
    match /users/{uid} {
      allow read:  if signedIn();
      allow write: if request.auth.uid == uid;

      // Personal map data — private to the owner (subcollections don't inherit the rule above).
      match /places/{key}      { allow read, write: if request.auth.uid == uid; }
      match /collections/{cid} { allow read, write: if request.auth.uid == uid; }
    }

    // Profile banners — kept out of users/{uid} so friend search stays light. Read by anyone signed in
    // (shown on profile cards); written only by the owner.
    match /user_banners/{uid} {
      allow read:  if signedIn();
      allow write: if request.auth.uid == uid;
    }

    // FCM push tokens — owner writes only. The Cloud Function reads these via the Admin SDK (which
    // bypasses rules), so clients never need read access.
    match /fcm_tokens/{uid} {
      allow read, write: if request.auth.uid == uid;
    }

    // @tag uniqueness index. A handle can only point at yourself; only its owner may change/release it.
    match /usernames/{tagLower} {
      allow read:   if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if signedIn() && resource.data.uid == request.auth.uid
                       && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Groups — members read; owner creates; members update (roles enforced in-app); owner deletes.
    match /groups/{gid} {
      allow read:   if signedIn() && request.auth.uid in resource.data.members;
      allow create: if request.auth.uid == request.resource.data.owner
                    && request.auth.uid in request.resource.data.members;
      allow update: if signedIn() && request.auth.uid in resource.data.members;
      allow delete: if request.auth.uid == resource.data.owner;

      // Chat — members post their own messages; system notices (trip join/left) post with from="system".
      match /messages/{mid} {
        allow read:   if member(gid);
        allow create: if member(gid)
                      && (request.resource.data.from == request.auth.uid
                          || request.resource.data.get('system', false) == true);
        // Authors may edit/unsend their own messages (from must stay themselves).
        allow update: if member(gid) && resource.data.from == request.auth.uid
                      && request.resource.data.from == request.auth.uid;
        allow delete: if member(gid) && resource.data.from == request.auth.uid;
      }

      // Shared trip pins — any member may add/edit/delete.
      match /trip_pins/{pid} {
        allow read:           if member(gid);
        allow create:         if member(gid) && request.resource.data.from == request.auth.uid;
        allow update, delete: if member(gid);
      }

      // Collection offers (trip-only "share collection") — any member reads; sharer creates; members clear on trip end.
      match /trip_offers/{oid} {
        allow read:   if member(gid);
        allow create: if member(gid) && request.resource.data.from == request.auth.uid;
        allow delete: if member(gid);
      }

      // Trip plan (shared objective queue) — any member reads and edits.
      match /trip_plan/{doc} {
        allow read, write: if member(gid);
      }
    }

    // Trip participation — ONE doc per user keyed by uid (single-trip-at-a-time).
    // You write only your own; any group member may delete a participant when ending the session.
    match /trip_participants/{uid} {
      allow read:           if signedIn();
      allow create, update: if request.auth.uid == uid;
      allow delete:         if request.auth.uid == uid || member(resource.data.gid);
    }

    // Live location shares — ONE doc per user keyed by uid; you write only your own, anyone signed in can view.
    match /live_shares/{uid} {
      allow read:  if signedIn();
      allow write: if request.auth.uid == uid;
    }

    // Private 1-on-1 chats — chatId is the two uids sorted and joined by "_", so the doc id already
    // names both participants. Checking the id beats get()ing the parent: no extra read, and the
    // first message can land in the same batch as the chat doc that would not exist yet.
    match /private_chats/{chatId} {
      // create keys off the doc id (the doc doesn't exist yet, so there's no resource.data to read).
      allow create:       if signedIn() && request.auth.uid in chatId.split('_');
      // read/update key off the `users` field so COLLECTION QUERIES work — an id-based rule
      // (chatId.split) only works for direct gets, not list queries, which left the inbox empty.
      allow read, update: if signedIn() && request.auth.uid in resource.data.users;

      match /messages/{mid} {
        allow read:   if signedIn() && request.auth.uid in chatId.split('_');
        allow create: if signedIn() && request.auth.uid in chatId.split('_')
                      && request.resource.data.from == request.auth.uid;
        // Authors may edit/unsend their own messages (from must stay themselves).
        allow update: if signedIn() && request.auth.uid in chatId.split('_')
                      && resource.data.from == request.auth.uid
                      && request.resource.data.from == request.auth.uid;
        allow delete: if signedIn() && request.auth.uid in chatId.split('_')
                      && resource.data.from == request.auth.uid;
      }
    }

    // Calls — 1:1 signalling doc. callId is the two uids sorted + joined by "_" (= LiveKit room name),
    // so the id names both participants. create keys off the id (doc doesn't exist yet); read/update/
    // delete key off from/to so the "incoming calls where to == me" query works and only the pair can act.
    match /calls/{callId} {
      allow create: if signedIn() && request.auth.uid in callId.split('_');
      // Read/update/delete: the id already names both participants, so authorize off the id — this also
      // works when the doc doesn't exist yet (the caller's listener races its own create write, and a
      // resource.data-based rule would deny on the null doc and kill the listener). The resource.data.to
      // branch is what makes the "incoming calls where to == me" collection query provably safe.
      allow read, update, delete: if signedIn()
                                  && (request.auth.uid in callId.split('_')
                                      || request.auth.uid == resource.data.to
                                      || request.auth.uid == resource.data.from);
    }

    // Group calls — shared room keyed by gid (= LiveKit room). Any group member may join/leave/read.
    match /group_calls/{gid} {
      allow read, write: if member(gid);
    }

    // Friend requests — sender creates; either party reads/deletes.
    match /friendRequests/{id} {
      allow create:       if signedIn() && request.resource.data.from == request.auth.uid;
      allow read, delete: if signedIn()
                          && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // Friendships — either member of the pair may create/read/delete/update the edge.
    match /friendships/{pairId} {
      allow read, delete: if signedIn() && request.auth.uid in resource.data.users;
      allow create:       if signedIn() && request.auth.uid in request.resource.data.users;
      allow update:       if signedIn() && request.auth.uid in resource.data.users
                             && request.auth.uid in request.resource.data.users;
    }
  }
}
