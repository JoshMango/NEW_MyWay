<?xml version="1.0" encoding="utf-8"?>
<!-- Place this file at res/values-night/theme.xml (same filename as your existing res/values/theme.xml).
     Android automatically swaps to whatever is in a "-night" resource folder when the system is
     in dark mode, so you don't need any code to detect the setting yourself. -->
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MyWay" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#00BCD4</item>
        <item name="colorPrimaryDark">#0097A7</item>
        <item name="colorPrimaryVariant">#0097A7</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#00c99d</item>
        <item name="colorSecondaryVariant">#00ACC1</item>
        <item name="colorOnSecondary">@android:color/white</item>
        <item name="android:colorBackground">#F0FDFE</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1E293B</item>
        <item name="android:statusBarColor">#0097A7</item>
        <item name="android:navigationBarColor">#0097A7</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- The only thing this night variant actually changes vs. the light theme. -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@android:color/black</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@drawable/ic_launcher_foreground</item>
    </style>
</resources>