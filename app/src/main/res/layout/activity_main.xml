<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- ── FULL SCREEN MAP ─────────────────────────────────────────── -->
    <fragment
        android:id="@+id/map_main"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ── TOP HEADER BAR ───────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/top_header"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_gravity="top"
        android:background="@drawable/gradient_header"
        android:elevation="10dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="15dp"
        android:paddingEnd="16dp">

        <!-- App title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="GPS Tracker"
            android:textColor="@android:color/white"
            android:textSize="28sp"
            android:layout_marginLeft="60dp"
            android:layout_marginTop="20dp"
            android:textStyle="bold" />

        <!-- Waypoint counter badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_bg"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="4dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp"
            android:layout_marginTop="5dp"
            android:elevation="8dp">

            <TextView
                android:id="@+id/tv_countCrumbs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="waypoints"
                android:textColor="@android:color/white"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>


    <!-- ── SEARCH BAR ────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/search_container"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="105dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="12dp"
        android:orientation="vertical"
        android:elevation="25dp">

        <!-- Search input row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/sidebar_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search location..."
                android:textColorHint="@color/text_light"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text"/>

            <TextView
                android:id="@+id/btn_search_clear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="@color/text_mid"
                android:textSize="14sp"
                android:padding="4dp"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Autocomplete dropdown -->
        <ListView
            android:id="@+id/lv_autocomplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/sidebar_bg"
            android:divider="@color/divider_color"
            android:dividerHeight="1dp"
            android:visibility="gone"/>
    </LinearLayout>


    <!-- ── HAMBURGER BUTTON (below header) ──────────────────────────── -->
    <LinearLayout
        android:id="@+id/btn_hamburger"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="start|top"
        android:layout_marginStart="10dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/sidebar_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☰"
            android:textColor="@color/text_dark"
            android:textSize="22sp" />
    </LinearLayout>

    <!-- ── LEFT SIDEBAR (below hamburger) ───────────────────────────── -->
    <LinearLayout
        android:id="@+id/left_sidebar"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:layout_marginStart="5dp"
        android:layout_marginTop="120dp"
        android:background="@drawable/sidebar_bg"
        android:elevation="28dp"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <!-- Add Waypoint -->
        <LinearLayout
            android:id="@+id/btn_newWaypoint"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/sidebar_btnbg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Add Waypoint"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- View Waypoints -->
        <LinearLayout
            android:id="@+id/btn_showWaypoint"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/sidebar_btnbg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Saved Waypoints"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Choose Address -->
        <LinearLayout
            android:id="@+id/btn_setLocation"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/sidebar_btnbg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎯"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Set Address"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="8dp"
            android:background="@color/divider_color" />

        <!-- Location Tracking Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/sidebar_btnbg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡"
                android:textSize="18sp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Tracking"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_locationsupdates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="@color/switch_thumb"
                app:trackTint="@color/switch_track" />
        </LinearLayout>

        <!-- GPS Mode Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/sidebar_btnbg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛰️"
                android:textSize="18sp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="GPS Mode"
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_gps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/switch_thumb"
                app:trackTint="@color/switch_track" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="8dp"
            android:background="@color/divider_color" />

        <!-- Dark mode toggle -->
        <LinearLayout
            android:id="@+id/btn_toggle_theme"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/sidebar_btnbg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙"
                android:textSize="18sp" />
            <TextView
                android:id="@+id/txt_toggletheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text=""
                android:textColor="@color/text_dark"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ── BOTTOM INFO CARD ──────────────────────────────────────────── -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="@color/card_background">

        <!-- Address row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:layout_marginBottom="10dp">

            <!-- Address info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍"
                    android:textSize="16sp"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Address"
                        android:textColor="@color/text_mid"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tv_address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Waiting for location..."
                        android:textColor="@color/text_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>
            <TextView
                android:id="@+id/tv_savedAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:background="@drawable/saved_address_bg"
                android:padding="6dp"
                android:text=""
                android:textColor="#059669"
                android:textSize="11sp"
                android:textStyle="italic"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Action buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:id="@+id/btn_save_location"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_bg"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💾"
                        android:textSize="13sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Save"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_pin_on_map"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/button_bg"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📌"
                        android:textSize="13sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:id="@+id/tv_pin_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pin mode"
                        android:textColor="@color/text_dark"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_share_location"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/button_bg"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📤"
                        android:textSize="13sp"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Share"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Stats grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Lat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/data_background"
                    android:padding="10dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LAT"
                        android:textColor="@color/text_mid"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_lat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.000"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Lng -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/data_background"
                    android:padding="10dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LNG"
                        android:textColor="@color/text_mid"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_lon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.000"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Alt -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/data_background"
                    android:padding="10dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ALT"
                        android:textColor="@color/text_mid"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_altitude"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Accuracy -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/data_background"
                    android:padding="10dp"
                    android:layout_marginEnd="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACC"
                        android:textColor="@color/text_mid"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_accuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/data_background"
                    android:padding="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPD"
                        android:textColor="@color/text_mid"
                        android:textSize="10sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_speed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0km/h"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Hidden TextViews -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">
        <TextView android:id="@+id/tv_labellat" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tv_labellon" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tv_labelaltitude" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tv_labelaccuracy" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tv_labelspeed" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tv_lbladdress" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tv_labelupdates" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tv_labelsensor" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <TextView android:id="@+id/tv_labelCrumb" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>