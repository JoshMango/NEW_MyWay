<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/map_picker"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_panel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── SEARCH BAR OVERLAY ───────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/picker_search_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:elevation="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Search input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/sidebar_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"/>
            <EditText
                android:id="@+id/et_picker_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search for a place..."
                android:textColorHint="@color/text_light"
                android:textColor="@color/text_dark"
                android:textSize="14sp"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text"/>
            <TextView
                android:id="@+id/btn_picker_search_clear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textColor="@color/text_mid"
                android:textSize="14sp"
                android:padding="4dp"
                android:visibility="gone"/>
        </LinearLayout>
        <!-- Autocomplete dropdown -->
        <ListView
            android:id="@+id/lv_picker_autocomplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/sidebar_bg"
            android:divider="@color/divider_color"
            android:dividerHeight="1dp"
            android:visibility="gone"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottom_panel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/card_background"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Coords + address -->
            <TextView
                android:id="@+id/tv_pickedCoords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tap or drag pin to select location"
                android:textSize="12sp"
                android:textColor="@color/text_mid" />

            <TextView
                android:id="@+id/tv_pickedAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"
                android:text="Resolving address..."
                android:textSize="14sp"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Name input (only shown in waypoint mode) -->
            <LinearLayout
                android:id="@+id/layout_waypoint_inputs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Name field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waypoint Name"
                    android:textColor="@color/text_mid"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:background="@drawable/data_background"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📌"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"/>

                    <EditText
                        android:id="@+id/et_waypoint_name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="e.g. Home, Office, Park..."
                        android:textColorHint="@color/text_light"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:inputType="textCapSentences"
                        android:maxLines="1"
                        android:imeOptions="actionNext"/>
                </LinearLayout>

                <!-- Notes field -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notes / Label"
                    android:textColor="@color/text_mid"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/data_background"
                    android:gravity="top"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📝"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp"/>

                    <EditText
                        android:id="@+id/et_waypoint_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="Add a note or label for this location..."
                        android:textColorHint="@color/text_light"
                        android:textColor="@color/text_dark"
                        android:textSize="14sp"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2"
                        android:maxLines="4"
                        android:gravity="top"
                        android:imeOptions="actionDone"/>
                </LinearLayout>

                <!-- add to collections button -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COLLECTION"
                    android:textColor="@color/text_mid"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:id="@+id/btn_add_to_collection"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:background="@drawable/data_background"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📁"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tv_selected_collection"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tap to choose a collection..."
                        android:textColor="@color/text_light"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="▶"
                        android:textColor="@color/text_mid"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_setAddress"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#00c99d"
                android:textColor="@android:color/white"
                android:text="Set Address"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:cornerRadius="15dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>