<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/info_window"
    android:padding="12dp"
    android:minWidth="180dp">

    <!-- Location Title -->
    <TextView
        android:id="@+id/tv_info_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#1E293B"
        android:textSize="14sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end" />

    <!-- Note text (shown when note exists) -->
    <TextView
        android:id="@+id/tv_info_snippet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:maxLines="3"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="#E2E8F0" />

    <!-- Add Note Button -->
    <LinearLayout
        android:id="@+id/btn_add_note"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="@drawable/note_button"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/tv_note_btn_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ Add Note"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Delete Location Button -->
    <LinearLayout
        android:id="@+id/btn_delete_location"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="@drawable/delete_btn"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑️ Delete Location"
            android:textColor="#ef4444"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>